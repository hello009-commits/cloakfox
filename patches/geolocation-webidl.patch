@@ -0,0 +1,62 @@
+/* Cloakfox: Per-context geolocation override manager */
+#include "GeolocationOverrideManager.h"
+#include "mozilla/dom/BrowsingContext.h"
+#include "nsGlobalWindowInner.h"
+
+namespace mozilla {
+namespace dom {
+
+void GeolocationOverrideManager::Set(uint32_t aId, double aLat, double aLon, double aAccuracy) {
+  nsAutoString k;
+  k.AppendPrintf("geo_lat_%u", aId);
+  RoverfoxStorageManager::PutUint(k, static_cast<uint32_t>((aLat + 90.0) * 100000));
+  k.Truncate(); k.AppendPrintf("geo_lon_%u", aId);
+  RoverfoxStorageManager::PutUint(k, static_cast<uint32_t>((aLon + 180.0) * 100000));
+  k.Truncate(); k.AppendPrintf("geo_acc_%u", aId);
+  RoverfoxStorageManager::PutUint(k, static_cast<uint32_t>(aAccuracy * 100));
+  k.Truncate(); k.AppendPrintf("geo_set_%u", aId);
+  RoverfoxStorageManager::PutBool(k, true);
+}
+
+bool GeolocationOverrideManager::HasOverride(uint32_t aId) {
+  nsAutoString k;
+  k.AppendPrintf("geo_set_%u", aId);
+  bool val = false;
+  return RoverfoxStorageManager::GetBool(k, val) && val;
+}
+
+bool GeolocationOverrideManager::GetLat(uint32_t aId, double& aOut) {
+  nsAutoString k; k.AppendPrintf("geo_lat_%u", aId);
+  uint32_t raw = 0;
+  if (!RoverfoxStorageManager::GetUint(k, raw)) return false;
+  aOut = (static_cast<double>(raw) / 100000.0) - 90.0;
+  return true;
+}
+
+bool GeolocationOverrideManager::GetLon(uint32_t aId, double& aOut) {
+  nsAutoString k; k.AppendPrintf("geo_lon_%u", aId);
+  uint32_t raw = 0;
+  if (!RoverfoxStorageManager::GetUint(k, raw)) return false;
+  aOut = (static_cast<double>(raw) / 100000.0) - 180.0;
+  return true;
+}
+
+bool GeolocationOverrideManager::GetAccuracy(uint32_t aId, double& aOut) {
+  nsAutoString k; k.AppendPrintf("geo_acc_%u", aId);
+  uint32_t raw = 0;
+  if (!RoverfoxStorageManager::GetUint(k, raw)) return false;
+  aOut = static_cast<double>(raw) / 100.0;
+  return true;
+}
+
+nsString GeolocationOverrideManager::DisabledKeyForUserContext(uint32_t aId) {
+  nsAutoString key; key.AppendPrintf("geo_d_%u", aId);
+  return key;
+}
+
+bool GeolocationOverrideManager::IsFunctionEnabledForWebIDL(JSContext* cx, JSObject* global) {
+  return ManagerBase::IsFunctionEnabledForWebIDLImpl(cx, global);
+}
+
+}  // namespace dom
+}  // namespace mozilla
