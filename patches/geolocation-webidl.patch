+void nsGlobalWindowInner::SetGeolocation(double aLat, double aLon, double aAccuracy,
+                                          ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  GeolocationOverrideManager::Set(userContextId, aLat, aLon, aAccuracy);
+  if (userContextId != 0) GeolocationOverrideManager::Set(0, aLat, aLon, aAccuracy);
+  GeolocationOverrideManager::DisableFunction(userContextId);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setGeolocation", undef);
+      JS_DeleteProperty(cx, global, "setGeolocation");
     }
   }
 }
