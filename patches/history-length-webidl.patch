+void nsGlobalWindowInner::SetHistoryLength(uint32_t aLength, ErrorResult& aRv) {
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+  HistoryLengthManager::SetLength(userContextId, aLength);
+  if (userContextId != 0) HistoryLengthManager::SetLength(0, aLength);
+  HistoryLengthManager::DisableFunction(userContextId);
+  if (JSContext* cx = nsContentUtils::GetCurrentJSContext()) {
+    JS::Rooted<JSObject*> global(cx, JS::CurrentGlobalOrNull(cx));
+    if (global) {
+      JS::Rooted<JS::Value> undef(cx, JS::UndefinedValue());
+      JS_SetProperty(cx, global, "setHistoryLength", undef);
+      JS_DeleteProperty(cx, global, "setHistoryLength");
+    }
+  }
+}
