+void HistoryLengthManager::SetLength(uint32_t aId, uint32_t aLength) {
+  nsAutoString key;
+  key.AppendPrintf("history_len_%u", aId);
+  RoverfoxStorageManager::PutUint(key, aLength);
+}
+
+bool HistoryLengthManager::GetLength(uint32_t aId, uint32_t& aOut) {
+  nsAutoString key;
+  key.AppendPrintf("history_len_%u", aId);
+  return RoverfoxStorageManager::GetUint(key, aOut) && aOut > 0;
+}
+
+nsString HistoryLengthManager::DisabledKeyForUserContext(uint32_t aId) {
+  nsAutoString key;
+  key.AppendPrintf("histlen_d_%u", aId);
+  return key;
+}
+
+bool HistoryLengthManager::IsFunctionEnabledForWebIDL(JSContext* cx, JSObject* global) {
+  return ManagerBase::IsFunctionEnabledForWebIDLImpl(cx, global);
+}
